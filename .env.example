# ── Local docker-compose.yml ───────────────────────────────────────────────
# Host port mapped to the Postgres container (default: 5432).
# Change if 5432 is already occupied on your machine.
POSTGRES_HOST_PORT=5432

# ── Traefik deployment (docker-compose.traefik.yml) ────────────────────────
TZ=Europe/Moscow

# Build-time proxy (npm/composer inside the builder reach the proxy via host network)
BUILD_HTTP_PROXY=http://127.0.0.1:1081
BUILD_HTTPS_PROXY=http://127.0.0.1:1081
BUILD_NO_PROXY=localhost,127.0.0.1,.local

# Domain routed by Traefik (frontend at /, backend at /api on the same host)
APP_DOMAIN=render-lab.example.com

# Postgres
POSTGRES_DB=render_lab
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# Backend secrets (generate strong random values, min 32 chars)
JWT_SECRET=change-me-jwt-secret-min-32-characters
PASSWORD_PEPPER=change-me-password-pepper-min-32-chars
PASSWORD_WORK_FACTOR=11

# Auth cookie (COOKIE_SECURE forced to true in the Traefik compose)
COOKIE_NAME=auth_token
COOKIE_PATH=/
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax
